// AEHOP — Prisma schema (PostgreSQL). Conventions per System Blueprint §7:
// UUID PKs, snake_case columns via @map, createdAt/updatedAt, soft deletes.

generator client {
  provider = "prisma-client-js"
  // "native" for local; rhel target for Vercel/AWS Lambda serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Supabase: runtime uses the transaction pooler (pgBouncer); migrations use the
  // direct/session connection. See backend/.env.example for both strings.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================ Auth & Identity (Domain §3.1) ============================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  isActive     Boolean   @default(true) @map("is_active")
  employeeId   String?   @map("employee_id")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  roles            UserRole[]
  extraPermissions UserPermission[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      PermissionAction
  description String

  roles RolePermission[]
  users UserPermission[]

  @@unique([module, action])
  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Direct grants override role grants (Domain rule).
model UserPermission {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  granted      Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  APPROVE
  EXPORT
  PRINT
}

// ============================ Rooms (Domain §3.2) ============================

model RoomType {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  description      String
  maxOccupancy     Int      @map("max_occupancy")
  bedConfiguration String   @map("bed_configuration")
  basePrice        Decimal  @map("base_price") @db.Decimal(12, 2)
  features         String[]
  images           String[]
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  rooms        Room[]
  reservations Reservation[]
  pricing      RoomPricing[]

  @@map("room_types")
}

model Room {
  id         String     @id @default(uuid())
  roomNumber String     @unique @map("room_number")
  floor      Int
  roomTypeId String     @map("room_type_id")
  status     RoomStatus @default(AVAILABLE)
  isActive   Boolean    @default(true) @map("is_active")
  notes      String?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  roomType     RoomType      @relation(fields: [roomTypeId], references: [id])
  reservations Reservation[]
  checkIns     CheckIn[]

  @@index([roomTypeId])
  @@index([status])
  @@map("rooms")
}

model RoomPricing {
  id           String   @id @default(uuid())
  roomTypeId   String   @map("room_type_id")
  label        String
  pricePerNight Decimal @map("price_per_night") @db.Decimal(12, 2)
  validFrom    DateTime @map("valid_from")
  validTo      DateTime @map("valid_to")
  isDefault    Boolean  @default(false) @map("is_default")
  roomType     RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@map("room_pricing")
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  INSPECTION
  MAINTENANCE
  OUT_OF_ORDER
  BLOCKED
}

// ============================ Guests (Domain §3.3) ============================

model Guest {
  id            String    @id @default(uuid())
  title         Title?
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String?
  phone         String
  nationality   String?
  dateOfBirth   DateTime? @map("date_of_birth")
  idType        IdType?   @map("id_type")
  idNumber      String?   @map("id_number")
  addressStreet String?   @map("address_street")
  addressCity   String?   @map("address_city")
  addressCountry String?  @map("address_country")
  notes         String?
  isVip         Boolean   @default(false) @map("is_vip")
  isBlacklisted Boolean   @default(false) @map("is_blacklisted")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  reservations Reservation[]
  documents    GuestDocument[]
  folios       Folio[]
  orders       Order[]

  @@index([phone])
  @@map("guests")
}

model GuestDocument {
  id           String   @id @default(uuid())
  guestId      String   @map("guest_id")
  documentType String   @map("document_type")
  fileKey      String   @map("file_key")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  guest        Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("guest_documents")
}

enum Title {
  MR
  MRS
  MS
  DR
  PROF
  OTHER
}

enum IdType {
  PASSPORT
  NATIONAL_ID
  DRIVER_LICENSE
}

// ============================ Reservations (Domain §3.4) ============================

model Reservation {
  id                 String            @id @default(uuid())
  reservationNumber  String            @unique @map("reservation_number")
  guestId            String            @map("guest_id")
  roomId             String?           @map("room_id")
  roomTypeId         String            @map("room_type_id")
  checkInDate        DateTime          @map("check_in_date") @db.Date
  checkOutDate       DateTime          @map("check_out_date") @db.Date
  adults             Int               @default(1)
  children           Int               @default(0)
  status             ReservationStatus @default(PENDING)
  source             ReservationSource @default(WEBSITE)
  specialRequests    String?           @map("special_requests")
  totalAmount        Decimal           @map("total_amount") @db.Decimal(12, 2)
  depositAmount      Decimal           @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  depositPaid        Boolean           @default(false) @map("deposit_paid")
  confirmedAt        DateTime?         @map("confirmed_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancellationReason String?           @map("cancellation_reason")
  createdByUserId    String?           @map("created_by_user_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  guest    Guest     @relation(fields: [guestId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])
  roomType RoomType  @relation(fields: [roomTypeId], references: [id])
  checkIns CheckIn[]

  @@index([guestId])
  @@index([status])
  @@index([roomId, checkInDate, checkOutDate])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  WEBSITE
  WALK_IN
  PHONE
  OTA
  INTERNAL
}

// ============================ Reception (Domain §3.5) ============================

model CheckIn {
  id             String    @id @default(uuid())
  reservationId  String?   @map("reservation_id")
  guestId        String    @map("guest_id")
  roomId         String    @map("room_id")
  checkedInAt    DateTime  @default(now()) @map("checked_in_at")
  checkedInByUserId String @map("checked_in_by_user_id")
  keyIssued      Boolean   @default(false) @map("key_issued")

  reservation Reservation? @relation(fields: [reservationId], references: [id])
  room        Room         @relation(fields: [roomId], references: [id])
  folio       Folio?
  checkOut    CheckOut?

  @@map("check_ins")
}

model CheckOut {
  id              String        @id @default(uuid())
  checkInId       String        @unique @map("check_in_id")
  guestId         String        @map("guest_id")
  roomId          String        @map("room_id")
  checkedOutAt    DateTime      @default(now()) @map("checked_out_at")
  checkedOutByUserId String     @map("checked_out_by_user_id")
  totalCharged    Decimal       @map("total_charged") @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  checkIn         CheckIn       @relation(fields: [checkInId], references: [id])

  @@map("check_outs")
}

model Folio {
  id        String      @id @default(uuid())
  guestId   String      @map("guest_id")
  checkInId String      @unique @map("check_in_id")
  status    FolioStatus @default(OPEN)
  openedAt  DateTime    @default(now()) @map("opened_at")
  settledAt DateTime?   @map("settled_at")

  guest   Guest       @relation(fields: [guestId], references: [id])
  checkIn CheckIn     @relation(fields: [checkInId], references: [id])
  lines   FolioLine[]

  @@map("folios")
}

model FolioLine {
  id          String        @id @default(uuid())
  folioId     String        @map("folio_id")
  description String
  amount      Decimal       @db.Decimal(12, 2)
  type        FolioLineType
  referenceId String?       @map("reference_id")
  postedAt    DateTime      @default(now()) @map("posted_at")
  folio       Folio         @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@map("folio_lines")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
}

enum FolioStatus {
  OPEN
  SETTLED
  DISPUTED
}

enum FolioLineType {
  ROOM_CHARGE
  RESTAURANT
  LOUNGE
  BOUTIQUE
  DAMAGE
  SERVICE
  DISCOUNT
  TAX
}

// ============================ Service: Restaurant / Lounge (Domain §4) ============================

model MenuCategory {
  id         String     @id @default(uuid())
  storefront Storefront
  name       String
  imageKey   String?    @map("image_key")
  sortOrder  Int        @default(0) @map("sort_order")
  isActive   Boolean    @default(true) @map("is_active")
  items      MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              String       @id @default(uuid())
  categoryId      String       @map("category_id")
  storefront      Storefront
  name            String
  description     String?
  price           Decimal      @db.Decimal(12, 2)
  imageKey        String?      @map("image_key")
  isAvailable     Boolean      @default(true) @map("is_available")
  isSeasonal      Boolean      @default(false) @map("is_seasonal")
  isHidden        Boolean      @default(false) @map("is_hidden")
  tags            String[]
  preparationTime Int?         @map("preparation_time")
  sortOrder       Int          @default(0) @map("sort_order")
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([storefront])
  @@map("menu_items")
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique @map("order_number")
  storefront          Storefront
  source              OrderSource
  guestId             String?     @map("guest_id")
  roomNumber          String?     @map("room_number")
  tableNumber         String?     @map("table_number")
  customerName        String?     @map("customer_name")
  customerPhone       String?     @map("customer_phone")
  deliveryLocation    String?     @map("delivery_location")
  specialInstructions String?     @map("special_instructions")
  status              OrderStatus @default(PENDING)
  totalAmount         Decimal     @map("total_amount") @db.Decimal(12, 2)
  handledByUserId     String?     @map("handled_by_user_id")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  guest Guest?      @relation(fields: [guestId], references: [id])
  items OrderItem[]

  @@index([storefront])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  menuItemId String   @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  notes      String?
  subtotal   Decimal  @db.Decimal(12, 2)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model RestaurantTable {
  id          String      @id @default(uuid())
  tableNumber String      @unique @map("table_number")
  capacity    Int
  status      TableStatus @default(AVAILABLE)

  @@map("restaurant_tables")
}

enum Storefront {
  RESTAURANT
  LOUNGE
  BOUTIQUE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum OrderSource {
  INTERNAL_POS
  WEBSITE
  ROOM_SERVICE
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

// ============================ Audit Log (Domain §8.4) — append-only ============================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  module     String
  targetId   String?  @map("target_id")
  targetType String?  @map("target_type")
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@map("audit_logs")
}

// ============================ Inventory (Domain §5.1) ============================

enum InventoryDepartment {
  RESTAURANT
  LOUNGE
  BOUTIQUE
  HOUSEKEEPING
  MAINTENANCE
  OFFICE
  GENERAL
}

model InventoryItem {
  id            String              @id @default(uuid())
  name          String
  sku           String              @unique
  department    InventoryDepartment @default(GENERAL)
  unit          String
  currentQty    Int                 @default(0) @map("current_qty")
  minStockLevel Int                 @default(0) @map("min_stock_level")
  unitCost      Decimal             @default(0) @map("unit_cost") @db.Decimal(12, 2)
  location      String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("inventory_items")
}

// ============================ Maintenance (Domain §5.3) ============================

enum AssetStatus {
  OPERATIONAL
  INSPECTION_DUE
  NEEDS_REPAIR
  UNDER_REPAIR
  DECOMMISSIONED
}

enum AssetArea {
  ROOM
  POOL
  BAR
  RESTAURANT
  RECEPTION
  GYM
  LOUNGE
  KITCHEN
  EXTERIOR
  BACK_OF_HOUSE
  OTHER
}

model Asset {
  id             String      @id @default(uuid())
  assetNumber    String      @unique @map("asset_number")
  name           String
  category       String
  area           AssetArea   @default(OTHER)
  roomNumber     String?     @map("room_number")
  location       String
  status         AssetStatus @default(OPERATIONAL)
  nextInspection DateTime?   @map("next_inspection") @db.Date
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  workOrders     WorkOrder[]

  @@index([area])
  @@map("assets")
}

enum WorkOrderType {
  CORRECTIVE
  PREVENTIVE
  INSPECTION
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

model WorkOrder {
  id              String            @id @default(uuid())
  workOrderNumber String            @unique @map("work_order_number")
  assetId         String?           @map("asset_id")
  type            WorkOrderType     @default(CORRECTIVE)
  priority        WorkOrderPriority @default(NORMAL)
  status          WorkOrderStatus   @default(OPEN)
  assignedTo      String?           @map("assigned_to")
  estimatedCost   Decimal           @default(0) @map("estimated_cost") @db.Decimal(12, 2)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  asset           Asset?            @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@map("work_orders")
}

// ============================ HR (Domain §6.1) ============================

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

model Employee {
  id             String         @id @default(uuid())
  employeeNumber String         @unique @map("employee_number")
  name           String
  department     String
  position       String
  employmentType EmploymentType @default(FULL_TIME) @map("employment_type")
  status         EmployeeStatus @default(ACTIVE)
  startDate      DateTime       @map("start_date") @db.Date
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  leaveRequests  LeaveRequest[]

  @@map("employees")
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  COMPASSIONATE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id         String      @id @default(uuid())
  employeeId String      @map("employee_id")
  type       LeaveType   @default(ANNUAL)
  startDate  DateTime    @map("start_date") @db.Date
  endDate    DateTime    @map("end_date") @db.Date
  days       Int         @default(1)
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("leave_requests")
}

// ============================ Payroll (Domain §6.2) ============================

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CLOSED
}

model PayrollPeriod {
  id         String        @id @default(uuid())
  periodName String        @map("period_name")
  startDate  DateTime      @map("start_date") @db.Date
  endDate    DateTime      @map("end_date") @db.Date
  status     PayrollStatus @default(DRAFT)
  totalGross Decimal       @default(0) @map("total_gross") @db.Decimal(14, 2)
  totalNet   Decimal       @default(0) @map("total_net") @db.Decimal(14, 2)
  headcount  Int           @default(0)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@map("payroll_periods")
}

// ============================ Finance (Domain §7) ============================

enum TransactionType {
  REVENUE
  EXPENSE
  PAYROLL
  REFUND
}

enum TransactionDirection {
  DEBIT
  CREDIT
}

enum TransactionStatus {
  PENDING
  POSTED
  VOIDED
}

model FinanceTransaction {
  id                String               @id @default(uuid())
  transactionNumber String               @unique @map("transaction_number")
  type              TransactionType
  amount            Decimal              @db.Decimal(14, 2)
  direction         TransactionDirection
  account           String
  description       String
  date              DateTime             @db.Date
  status            TransactionStatus    @default(PENDING)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@map("finance_transactions")
}

// ============================ Housekeeping (Domain §5.2) ============================

enum HousekeepingType {
  CHECKOUT_CLEAN
  STAYOVER_CLEAN
  DEEP_CLEAN
  INSPECTION
  TURNDOWN
}

enum HousekeepingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum HousekeepingPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model HousekeepingTask {
  id         String               @id @default(uuid())
  roomNumber String               @map("room_number")
  type       HousekeepingType     @default(CHECKOUT_CLEAN)
  status     HousekeepingStatus   @default(PENDING)
  priority   HousekeepingPriority @default(NORMAL)
  assignedTo String?              @map("assigned_to")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  @@map("housekeeping_tasks")
}

// ============================ Settings (Domain §8.1) — singleton hotel profile ============================

model Setting {
  id        String   @id @default("hotel")
  hotelName String   @map("hotel_name")
  tagline   String   @default("")
  phone     String   @default("")
  whatsapp  String   @default("")
  email     String   @default("")
  address   String   @default("")
  city      String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
