{
  "info": {
    "name": "AEHOP API",
    "description": "Acemco Express Hotel Operations Platform API. Set the `baseUrl` environment variable, run **Auth → Login** first (it captures `accessToken` automatically), then call the authenticated endpoints. Public endpoints need no token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" },
    { "key": "accessToken", "value": "" },
    { "key": "roomId", "value": "" },
    { "key": "guestId", "value": "" },
    { "key": "reservationId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /v1/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.test('token captured', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ada@acemcohotel.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] }
          }
        },
        {
          "name": "POST /v1/auth/refresh",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "refresh"] }
          }
        },
        {
          "name": "POST /v1/auth/logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "logout"] }
          }
        },
        {
          "name": "GET /v1/auth/me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "GET /v1/rooms",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/rooms?status=AVAILABLE", "host": ["{{baseUrl}}"], "path": ["v1", "rooms"], "query": [{ "key": "status", "value": "AVAILABLE", "disabled": true }] }
          }
        },
        {
          "name": "GET /v1/rooms/:id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/rooms/{{roomId}}", "host": ["{{baseUrl}}"], "path": ["v1", "rooms", "{{roomId}}"] } }
        },
        {
          "name": "PATCH /v1/rooms/:id/status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CLEANING\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/rooms/{{roomId}}/status", "host": ["{{baseUrl}}"], "path": ["v1", "rooms", "{{roomId}}", "status"] }
          }
        },
        {
          "name": "GET /v1/room-types",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/room-types", "host": ["{{baseUrl}}"], "path": ["v1", "room-types"] } }
        }
      ]
    },
    {
      "name": "Guests",
      "item": [
        {
          "name": "GET /v1/guests",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/guests?page=1&pageSize=20", "host": ["{{baseUrl}}"], "path": ["v1", "guests"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }, { "key": "search", "value": "", "disabled": true }] } }
        },
        {
          "name": "GET /v1/guests/:id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/guests/{{guestId}}", "host": ["{{baseUrl}}"], "path": ["v1", "guests", "{{guestId}}"] } }
        },
        {
          "name": "POST /v1/guests",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Chidi\",\n  \"lastName\": \"Umeh\",\n  \"phone\": \"+234 800 123 4567\",\n  \"email\": \"chidi@example.com\",\n  \"isVip\": false\n}" },
            "url": { "raw": "{{baseUrl}}/v1/guests", "host": ["{{baseUrl}}"], "path": ["v1", "guests"] }
          }
        },
        {
          "name": "PATCH /v1/guests/:id",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"isVip\": true\n}" },
            "url": { "raw": "{{baseUrl}}/v1/guests/{{guestId}}", "host": ["{{baseUrl}}"], "path": ["v1", "guests", "{{guestId}}"] }
          }
        },
        {
          "name": "DELETE /v1/guests/:id",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/v1/guests/{{guestId}}", "host": ["{{baseUrl}}"], "path": ["v1", "guests", "{{guestId}}"] } }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "GET /v1/reservations",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/reservations?page=1&pageSize=20", "host": ["{{baseUrl}}"], "path": ["v1", "reservations"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }, { "key": "status", "value": "PENDING", "disabled": true }] } }
        },
        {
          "name": "GET /v1/reservations/:id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/reservations/{{reservationId}}", "host": ["{{baseUrl}}"], "path": ["v1", "reservations", "{{reservationId}}"] } }
        },
        {
          "name": "POST /v1/reservations",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"guestId\": \"{{guestId}}\",\n  \"roomTypeId\": \"<room-type-uuid from /v1/room-types>\",\n  \"checkInDate\": \"2026-08-01\",\n  \"checkOutDate\": \"2026-08-04\",\n  \"adults\": 2,\n  \"children\": 0,\n  \"source\": \"INTERNAL\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/reservations", "host": ["{{baseUrl}}"], "path": ["v1", "reservations"] }
          }
        },
        {
          "name": "POST /v1/reservations/:id/confirm",
          "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/v1/reservations/{{reservationId}}/confirm", "host": ["{{baseUrl}}"], "path": ["v1", "reservations", "{{reservationId}}", "confirm"] } }
        },
        {
          "name": "POST /v1/reservations/:id/cancel",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Guest requested cancellation\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/reservations/{{reservationId}}/cancel", "host": ["{{baseUrl}}"], "path": ["v1", "reservations", "{{reservationId}}", "cancel"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "GET /v1/orders",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/orders?storefront=RESTAURANT", "host": ["{{baseUrl}}"], "path": ["v1", "orders"], "query": [{ "key": "storefront", "value": "RESTAURANT" }, { "key": "status", "value": "PENDING", "disabled": true }] } }
        },
        {
          "name": "GET /v1/orders/:id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["v1", "orders", "{{orderId}}"] } }
        },
        {
          "name": "POST /v1/orders",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"storefront\": \"RESTAURANT\",\n  \"source\": \"INTERNAL_POS\",\n  \"tableNumber\": \"T04\",\n  \"items\": [\n    { \"menuItemId\": \"<menu-item-uuid from /public/menus/restaurant>\", \"quantity\": 2 }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/v1/orders", "host": ["{{baseUrl}}"], "path": ["v1", "orders"] }
          }
        },
        {
          "name": "POST /v1/orders/:id/advance",
          "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/v1/orders/{{orderId}}/advance", "host": ["{{baseUrl}}"], "path": ["v1", "orders", "{{orderId}}", "advance"] } }
        },
        {
          "name": "POST /v1/orders/:id/cancel",
          "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/v1/orders/{{orderId}}/cancel", "host": ["{{baseUrl}}"], "path": ["v1", "orders", "{{orderId}}", "cancel"] } }
        }
      ]
    },
    {
      "name": "Public (no auth)",
      "item": [
        {
          "name": "GET /public/rooms",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/public/rooms", "host": ["{{baseUrl}}"], "path": ["public", "rooms"] } }
        },
        {
          "name": "GET /public/rooms/:slug",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/public/rooms/deluxe-king", "host": ["{{baseUrl}}"], "path": ["public", "rooms", "deluxe-king"] } }
        },
        {
          "name": "GET /public/menus/:storefront",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/public/menus/restaurant", "host": ["{{baseUrl}}"], "path": ["public", "menus", "restaurant"] } }
        },
        {
          "name": "POST /public/reservations",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Web\",\n  \"lastName\": \"Guest\",\n  \"phone\": \"+234 801 000 0000\",\n  \"email\": \"web@example.com\",\n  \"roomTypeSlug\": \"deluxe-king\",\n  \"checkInDate\": \"2026-08-10\",\n  \"checkOutDate\": \"2026-08-12\",\n  \"adults\": 2,\n  \"children\": 0\n}" },
            "url": { "raw": "{{baseUrl}}/public/reservations", "host": ["{{baseUrl}}"], "path": ["public", "reservations"] }
          }
        },
        {
          "name": "POST /public/orders",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"storefront\": \"LOUNGE\",\n  \"items\": [\n    { \"menuItemId\": \"<menu-item-uuid from /public/menus/lounge>\", \"quantity\": 1 }\n  ],\n  \"customerName\": \"Ada Web\",\n  \"customerPhone\": \"+234 802 000 0000\",\n  \"deliveryLocation\": \"Poolside\"\n}" },
            "url": { "raw": "{{baseUrl}}/public/orders", "host": ["{{baseUrl}}"], "path": ["public", "orders"] }
          }
        }
      ]
    }
  ]
}
