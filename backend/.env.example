# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database — Supabase (get exact strings from Supabase → Connect).
# Runtime: transaction pooler (IPv4, pgBouncer, port 6543).
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations: session pooler (IPv4, port 5432).
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"
# Local Docker Postgres alternative: postgresql://aehop:aehop@localhost:5432/aehop_db?schema=public

# JWT (use long random secrets in production)
JWT_SECRET=change-me-access-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-diff
JWT_REFRESH_EXPIRES_IN=7d

# Refresh-cookie SameSite. Leave 'lax' when the app serves the API same-origin
# (recommended — via the Next rewrite / API_PROXY_TARGET). Use 'none' only if the
# API is on a different site than the app (requires HTTPS; browsers may block it).
COOKIE_SAMESITE=lax

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Vercel Cron auth for the night audit. Without it the audit refuses to run.
CRON_SECRET=change-me-generate-a-random-32-byte-string
