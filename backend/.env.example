# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL — matches docker-compose.yml)
DATABASE_URL="postgresql://aehop:aehop@localhost:5432/aehop_db?schema=public"

# JWT (use long random secrets in production)
JWT_SECRET=change-me-access-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-diff
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
